    "reviews_custom_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"padding:60px 20px;\"><h2 style=\"text-align:center;margin-bottom:40px;font-size:clamp(1.2rem,2.5vw,1.8rem);letter-spacing:0.05em;\">WHAT OUR CUSTOMERS SAY</h2><div style=\"display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;max-width:1100px;margin:0 auto;\"><div style=\"border:1px solid #e5e5e5;border-radius:8px;padding:24px;\"><div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px;\"><div style=\"width:48px;height:48px;border-radius:50%;background:#2d6a4f;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.95rem;flex-shrink:0;\">SM</div><div><strong style=\"display:block;\">Sarah M.</strong><span style=\"color:#f5a623;\">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div></div><p style=\"font-style:italic;color:#555;margin:0;\">&ldquo;This equipment completely changed my home workout routine. Amazing quality!&rdquo;</p></div><div style=\"border:1px solid #e5e5e5;border-radius:8px;padding:24px;\"><div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px;\"><div style=\"width:48px;height:48px;border-radius:50%;background:#1d4e89;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.95rem;flex-shrink:0;\">JT</div><div><strong style=\"display:block;\">James T.</strong><span style=\"color:#f5a623;\">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div></div><p style=\"font-style:italic;color:#555;margin:0;\">&ldquo;Finally I can sculpt my body without going to the gym. Best investment ever!&rdquo;</p></div><div style=\"border:1px solid #e5e5e5;border-radius:8px;padding:24px;\"><div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px;\"><div style=\"width:48px;height:48px;border-radius:50%;background:#7b2d8b;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.95rem;flex-shrink:0;\">ER</div><div><strong style=\"display:block;\">Emily R.</strong><span style=\"color:#f5a623;\">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div></div><p style=\"font-style:italic;color:#555;margin:0;\">&ldquo;Exceeded my expectations. Build quality is outstanding and so easy to use at home.&rdquo;</p></div><div style=\"border:1px solid #e5e5e5;border-radius:8px;padding:24px;\"><div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px;\"><div style=\"width:48px;height:48px;border-radius:50%;background:#b5451b;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.95rem;flex-shrink:0;\">MK</div><div><strong style=\"display:block;\">Michael K.</strong><span style=\"color:#f5a623;\">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div></div><p style=\"font-style:italic;color:#555;margin:0;\">&ldquo;Lost 10kg in 3 months using this. Highly recommend for anyone serious about fitness.&rdquo;</p></div></div></div>",
