                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "faq_accordion": {
              "type": "accordion",
              "settings": {
                "icon": "caret",
                "dividers": true,
                "type_preset": "h6",
                "inherit_color_scheme": true,
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 0,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {
                "faq_row_1": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Is this suitable for beginners or people who haven't exercised in years?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_1": {
                      "type": "text",
                      "settings": { "text": "<p>Absolutely! The Rock Stepper is designed for all fitness levels. Start with just 5-10 minutes daily and build up gradually. The low-impact motion is gentle on joints, and the video guides you through beginner-friendly routines.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_1"]
                },
                "faq_row_2": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "How do I safely get on and off the stepper?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_2": {
                      "type": "text",
                      "settings": { "text": "<p>Getting on is simple: Place one foot on the lower pedal, hold a chair\/wall if needed for balance, then step up with your other foot. After 2-3 uses, most people hop on and off naturally.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_2"]
                },
                "faq_row_3": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "How is this different from a regular mini stepper?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_3": {
                      "type": "text",
                      "settings": { "text": "<p>Regular steppers only go up and down, working just your legs. The Rock Stepper\u2019s patented lateral rocking motion engages your legs, glutes, AND core simultaneously \u2014 giving you 3x the workout in the same time.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_3"]
                },
                "faq_row_4": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "What's the weight limit?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_4": {
                      "type": "text",
                      "settings": { "text": "<p>The Rock Stepper\u2019s heavy-duty steel frame safely supports up to 350 lbs. The frame is tested to handle even vigorous workouts at maximum capacity without wobbling or breaking.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_4"]
                },
                "faq_row_5": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "How quickly will I see results?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_5": {
                      "type": "text",
                      "settings": { "text": "<p>Based on customer feedback:<br>Week 1\u20132: You\u2019ll feel more energized and sleep better<br>Week 3\u20134: You\u2019ll notice clothes fitting better<br>Week 6\u20138: Others will start asking what you\u2019ve been doing differently<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_5"]
                },
                "faq_row_6": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Will this work on carpet\/hardwood floors?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_6": {
                      "type": "text",
                      "settings": { "text": "<p>Yes! The included non-slip mat provides stability on any surface. For carpet, you may not even need the mat. On hardwood, the mat prevents sliding and protects your floors.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_6"]
                },
                "faq_row_7": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "What if I have bad knees or joint problems?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_7": {
                      "type": "text",
                      "settings": { "text": "<p>The Rock Stepper is specifically designed to be low-impact and joint-friendly. The smooth rocking motion actually helps lubricate joints without the harsh impact of running or regular stairs. However, always consult your doctor before starting any exercise program.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_7"]
                },
                "faq_row_8": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Does it require assembly or batteries?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_8": {
                      "type": "text",
                      "settings": { "text": "<p>Zero assembly needed! Unlike most exercise equipment, The Rock Stepper arrives 100% ready to use. Just unbox, place on the floor, and start rocking. No tools, no frustration.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_8"]
                },
                "faq_row_9": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Is there an app or online workout program I can follow?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_9": {
                      "type": "text",
                      "settings": { "text": "<p>Yes! Every Rock Stepper comes with exclusive workout guides that guide you through complete routines.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_9"]
                },
                "faq_row_10": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Can I return it if it's not for me?",
                    "open_by_default": false,
                    "icon": "question_mark",
                    "width": 20
                  },
                  "blocks": {
                    "faq_text_10": {
                      "type": "text",
                      "settings": { "text": "<p>Absolutely! We offer a 30-day money-back guarantee. Try it risk-free. If you don\u2019t love how you feel after 30 days, return it for a full refund.<\/p>", "width": "100%" }
                    }
                  },
                  "block_order": ["faq_text_10"]
                }
              },
              "block_order": [
                "faq_row_1","faq_row_2","faq_row_3","faq_row_4","faq_row_5",
                "faq_row_6","faq_row_7","faq_row_8","faq_row_9","faq_row_10"
              ]
            }
          },
          "block_order": [
            "group_icgrde",
            "divider_VJhene",
            "variant_picker_R3rGDr",
            "buy_now_block",
            "buy_buttons_eYQEYi",
            "text_aEtTtq",
