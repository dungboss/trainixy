            "buy_now_block": {
              "type": "custom-liquid",
              "settings": {
                "custom_liquid": "<style>.bn-btn{display:block;width:100%;padding:14px 24px;background:var(--color-primary);color:var(--color-on-primary,#fff);font-weight:700;font-size:1rem;border:2px solid var(--color-primary);border-radius:var(--style-border-radius-buttons-primary,6px);cursor:pointer;text-align:center;letter-spacing:0.04em;transition:opacity .2s}.bn-btn:hover{opacity:.85}.bn-btn:disabled{opacity:.6;cursor:not-allowed}<\/style><button class=\"bn-btn\" type=\"button\" data-variant-id=\"{{ closest.product.selected_or_first_available_variant.id }}\" onclick=\"(function(btn){btn.disabled=true;btn.textContent='Processing\u2026';var vid=btn.dataset.variantId;var sel=document.querySelector('input[name=id]:checked,select[name=id]');if(sel&&sel.value)vid=sel.value;fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:parseInt(vid),quantity:1})}).then(function(){window.location.href='\/checkout';}).catch(function(){btn.disabled=false;btn.textContent='Buy Now';});})(this)\">Buy Now<\/button>"
              },
