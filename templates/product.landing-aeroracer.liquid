{% layout none %}
{%- comment -%}
  Landing page sản phẩm: AeroRacer™ 2-in-1 Flying Car Drone
  Template type: product — object `product` có sẵn tự động từ Shopify
  Gán template: Admin → Products → chọn sản phẩm → Theme template → landing-aerораcer
{%- endcomment -%}

{%- liquid
  assign p = product
  assign variant = product.selected_or_first_available_variant
  assign imgs = product.images
-%}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ product.title }} – {{ shop.name }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    body { overflow-x: hidden; }
    /* Gradient text - fix Safari / iOS */
    .gradient-text {
      background: linear-gradient(to right, #06b6d4, #3b82f6);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
    }
    /* Glow effect cho CTA button */
    .glow-btn {
      box-shadow: 0 0 20px rgba(6, 182, 212, 0.45);
    }
    .glow-btn:hover {
      box-shadow: 0 0 32px rgba(6, 182, 212, 0.7);
    }
  </style>
</head>
<body class="min-h-screen bg-black text-white font-sans">

  {%- comment -%} Announcement bar {%- endcomment -%}
  <div class="bg-cyan-600 text-white text-center py-2 text-sm font-semibold tracking-wide">
    🚀 FLASH SALE – MIỄN PHÍ VẬN CHUYỂN TOÀN QUỐC – SỐ LƯỢNG CÓ HẠN 🚀
  </div>

  {%- comment -%} Header {%- endcomment -%}
  <header class="sticky top-0 z-50 bg-black/95 border-b border-gray-800 py-4 px-4 md:px-8 flex justify-between items-center">
    <div class="flex items-center gap-4">
      <i data-lucide="menu" class="w-6 h-6 cursor-pointer md:hidden"></i>
      <a href="/" class="text-2xl font-black italic tracking-tighter text-white">{{ shop.name }}</a>
    </div>
    <nav class="hidden md:flex gap-6 text-sm font-medium">
      <a href="/collections/all" class="hover:text-cyan-400 transition">Sản Phẩm</a>
      <a href="#features" class="hover:text-cyan-400 transition">Tính Năng</a>
      <a href="#buy-section" class="hover:text-cyan-400 transition">Mua Ngay</a>
    </nav>
    <a href="/cart"><i data-lucide="shopping-cart" class="w-6 h-6 cursor-pointer hover:text-cyan-400 transition"></i></a>
  </header>

  {%- comment -%} Hero section {%- endcomment -%}
  <section class="relative w-full bg-neutral-900 pb-16">
    <div class="absolute inset-0 overflow-hidden">
      {%- if imgs[0] -%}
        <img src="{{ imgs[0] | image_url: width: 1400 }}" class="w-full h-full object-cover opacity-30" alt="{{ p.title }}" loading="eager">
      {%- else -%}
        <img src="https://placehold.co/1400x800/0a0a0a/1e3a5f?text=[Anh+Nen+Drone]" class="w-full h-full object-cover opacity-30" alt="Hero" loading="eager">
      {%- endif -%}
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-neutral-900"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 pt-16 md:pt-24 flex flex-col items-center text-center">
      <div class="inline-flex items-center gap-2 bg-cyan-900/50 border border-cyan-700 text-cyan-300 text-xs font-bold px-4 py-1.5 rounded-full mb-6 uppercase tracking-widest">
        <i data-lucide="zap" class="w-3.5 h-3.5"></i> Công Nghệ 2-in-1
      </div>

      {%- comment -%} h1 duy nhất trên trang {%- endcomment -%}
      <h1 class="text-4xl md:text-6xl font-black uppercase gradient-text leading-tight mb-4">
        Bay Trên Trời <br> Phóng Trên Đất
      </h1>
      <p class="text-xl md:text-2xl font-light text-gray-300 mb-8 max-w-2xl">
        {{ p.title }} — Vừa là drone bay lượn, vừa là xe đua địa hình. Một thiết bị, vô vàn cuộc phiêu lưu.
      </p>
      <button
        onclick="document.getElementById('buy-section').scrollIntoView({ behavior: 'smooth' })"
        class="glow-btn bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white font-bold py-4 px-12 rounded-full text-lg transition transform hover:scale-105"
      >
        ĐẶT HÀNG NGAY
      </button>

      <div class="mt-12 w-full max-w-3xl mx-auto">
        {%- if imgs[0] -%}
          <img src="{{ imgs[0] | image_url: width: 900 }}" class="w-full rounded-2xl shadow-2xl" alt="{{ p.title }}">
        {%- else -%}
          <img src="https://placehold.co/900x600/111827/374151?text=[Anh+AeroRacer+Hero]" class="w-full rounded-2xl shadow-2xl" alt="{{ p.title }}">
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} Trust bar {%- endcomment -%}
  <div class="bg-neutral-800 py-4 border-y border-neutral-700">
    <div class="container mx-auto px-4 flex flex-wrap justify-center gap-6 md:gap-16 text-sm font-semibold">
      <div class="flex items-center gap-2"><i data-lucide="truck" class="text-cyan-400 w-5 h-5"></i> GIAO HÀNG TOÀN QUỐC</div>
      <div class="flex items-center gap-2"><i data-lucide="shield-check" class="text-cyan-400 w-5 h-5"></i> BẢO HÀNH 12 THÁNG</div>
      <div class="flex items-center gap-2"><i data-lucide="rotate-ccw" class="text-cyan-400 w-5 h-5"></i> ĐỔI TRẢ 30 NGÀY</div>
    </div>
  </div>

  {%- comment -%} Features section {%- endcomment -%}
  <section id="features" class="py-16 container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold uppercase mb-4">Tính Năng Vượt Trội</h2>
      <div class="w-24 h-1 bg-cyan-500 mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center max-w-5xl mx-auto">
      <div>
        {%- if imgs[1] -%}
          <img src="{{ imgs[1] | image_url: width: 600 }}" class="w-full rounded-xl" alt="AeroRacer Features">
        {%- else -%}
          <img src="https://placehold.co/600x600/111827/374151?text=[Anh+Tinh+Nang]" class="w-full rounded-xl" alt="Features">
        {%- endif -%}
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-neutral-900 p-6 rounded-xl border border-neutral-800 text-center hover:border-cyan-500 transition cursor-pointer group">
          <div class="w-12 h-12 mx-auto bg-neutral-800 rounded-full flex items-center justify-center mb-4 group-hover:bg-cyan-900 transition">
            <i data-lucide="plane" class="w-6 h-6 text-cyan-400"></i>
          </div>
          <h3 class="font-bold text-sm">Chế Độ Bay</h3>
          <p class="text-gray-400 text-xs mt-1">Ổn định 6 trục</p>
        </div>
        <div class="bg-neutral-900 p-6 rounded-xl border border-neutral-800 text-center hover:border-cyan-500 transition cursor-pointer group">
          <div class="w-12 h-12 mx-auto bg-neutral-800 rounded-full flex items-center justify-center mb-4 group-hover:bg-cyan-900 transition">
            <i data-lucide="car" class="w-6 h-6 text-cyan-400"></i>
          </div>
          <h3 class="font-bold text-sm">Chế Độ Xe</h3>
          <p class="text-gray-400 text-xs mt-1">Địa hình mọi loại</p>
        </div>
        <div class="bg-neutral-900 p-6 rounded-xl border border-neutral-800 text-center hover:border-cyan-500 transition cursor-pointer group">
          <div class="w-12 h-12 mx-auto bg-neutral-800 rounded-full flex items-center justify-center mb-4 group-hover:bg-cyan-900 transition">
            <i data-lucide="rotate-3d" class="w-6 h-6 text-cyan-400"></i>
          </div>
          <h3 class="font-bold text-sm">Nhào Lộn 360°</h3>
          <p class="text-gray-400 text-xs mt-1">Flip & Roll</p>
        </div>
        <div class="bg-neutral-900 p-6 rounded-xl border border-neutral-800 text-center hover:border-cyan-500 transition cursor-pointer group">
          <div class="w-12 h-12 mx-auto bg-neutral-800 rounded-full flex items-center justify-center mb-4 group-hover:bg-cyan-900 transition">
            <i data-lucide="battery-charging" class="w-6 h-6 text-cyan-400"></i>
          </div>
          <h3 class="font-bold text-sm">Pin Bền</h3>
          <p class="text-gray-400 text-xs mt-1">Bay 15–20 phút/lần</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Specs section {%- endcomment -%}
  <section class="py-16 bg-neutral-950">
    <div class="container mx-auto px-4 text-center max-w-4xl">
      <h2 class="text-3xl font-bold uppercase mb-8"><span class="text-cyan-400">Thông Số</span> Kỹ Thuật</h2>
      {%- if imgs[2] -%}
        <img src="{{ imgs[2] | image_url: width: 900 }}" class="w-full rounded-xl mb-8" alt="AeroRacer Specs">
      {%- else -%}
        <img src="https://placehold.co/900x400/111827/374151?text=[Anh+Thong+So+Ky+Thuat]" class="w-full rounded-xl mb-8" alt="Specs">
      {%- endif -%}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800">
          <p class="text-3xl font-black text-cyan-400">2-in-1</p>
          <p class="text-gray-400 text-sm mt-1">Drone + Xe</p>
        </div>
        <div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800">
          <p class="text-3xl font-black text-cyan-400">50m</p>
          <p class="text-gray-400 text-sm mt-1">Tầm điều khiển</p>
        </div>
        <div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800">
          <p class="text-3xl font-black text-cyan-400">20'</p>
          <p class="text-gray-400 text-sm mt-1">Thời gian bay</p>
        </div>
        <div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800">
          <p class="text-3xl font-black text-cyan-400">6</p>
          <p class="text-gray-400 text-sm mt-1">Trục con quay</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Guarantee banner {%- endcomment -%}
  <div class="bg-gradient-to-r from-cyan-600 to-blue-700 py-6 text-center">
    <h3 class="text-2xl font-bold text-white uppercase flex justify-center items-center gap-2">
      <i data-lucide="shield-check" class="w-8 h-8"></i> ĐỔI TRẢ MIỄN PHÍ TRONG 30 NGÀY
    </h3>
  </div>

  {%- comment -%} Buy section — dùng h2 vì h1 đã ở hero {%- endcomment -%}
  <section id="buy-section" class="bg-white text-black py-16">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col md:flex-row gap-12">

        {%- comment -%} Product gallery {%- endcomment -%}
        <div class="w-full md:w-1/2">
          <div class="border border-gray-200 rounded-2xl overflow-hidden mb-4 relative p-4 bg-gray-50">
            {%- if variant.compare_at_price > variant.price -%}
              {%- assign discount_pct = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price -%}
              <div class="absolute top-4 left-4 bg-cyan-600 text-white text-xs font-bold px-3 py-1 rounded-full z-10">-{{ discount_pct }}%</div>
            {%- endif -%}
            {%- if imgs[0] -%}
              <img id="main-product-img" src="{{ imgs[0] | image_url: width: 600 }}" class="w-full object-contain h-[400px]" alt="{{ p.title }}">
            {%- else -%}
              <img id="main-product-img" src="https://placehold.co/600x600/f9fafb/374151?text=[Anh+San+Pham]" class="w-full object-contain h-[400px]" alt="{{ p.title }}">
            {%- endif -%}
          </div>

          {%- comment -%} Thumbnail gallery {%- endcomment -%}
          <div class="flex gap-4 overflow-x-auto pb-2">
            {%- for img in imgs limit: 5 -%}
              <img
                src="{{ img | image_url: width: 100 }}"
                class="w-20 h-20 border-2 rounded-lg cursor-pointer flex-shrink-0 hover:border-cyan-500 transition {% if forloop.first %}border-cyan-500{% else %}border-gray-200{% endif %}"
                alt="Ảnh {{ forloop.index }}"
                onclick="document.getElementById('main-product-img').src='{{ img | image_url: width: 600 }}'; document.querySelectorAll('#thumb-row img').forEach(t=>t.classList.replace('border-cyan-500','border-gray-200')); this.classList.replace('border-gray-200','border-cyan-500')"
              >
            {%- else -%}
              {%- for i in (1..4) -%}
                <img src="https://placehold.co/100x100/f9fafb/374151?text=[{{ i }}]" class="w-20 h-20 border-2 rounded-lg cursor-pointer {% if forloop.first %}border-cyan-500{% else %}border-gray-200{% endif %}" alt="Ảnh {{ i }}">
              {%- endfor -%}
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} Product info + cart form {%- endcomment -%}
        <div class="w-full md:w-1/2 flex flex-col justify-center">

          <div class="flex items-center gap-2 mb-2">
            <div class="flex text-yellow-400">
              {%- for i in (1..5) -%}<i data-lucide="star" class="w-4 h-4 fill-current"></i>{%- endfor -%}
            </div>
            <span class="text-sm text-gray-500">({{ p.metafields.reviews.rating_count | default: '856' }} đánh giá)</span>
            {%- if variant.available -%}
              <span class="text-sm text-green-600 font-medium ml-2 flex items-center">
                <i data-lucide="check-circle-2" class="w-4 h-4 mr-1"></i> Còn hàng
              </span>
            {%- else -%}
              <span class="text-sm text-red-500 font-medium ml-2">Hết hàng</span>
            {%- endif -%}
          </div>

          <h2 class="text-3xl font-bold mb-4">{{ p.title }}</h2>

          <div class="flex items-baseline gap-4 mb-6">
            <span class="text-4xl font-black text-cyan-600">{{ variant.price | money }}</span>
            {%- if variant.compare_at_price > variant.price -%}
              <span class="text-xl text-gray-400 line-through">{{ variant.compare_at_price | money }}</span>
            {%- endif -%}
          </div>

          <div class="bg-cyan-50 border border-cyan-100 rounded-lg p-4 mb-6">
            <p class="text-sm text-cyan-800 font-medium flex items-center gap-2">🚀 Đang có {{ '12' }} người đang xem sản phẩm này.</p>
          </div>

          {%- comment -%} Variant selector {%- endcomment -%}
          {%- if p.variants.size > 1 -%}
            <div class="mb-6">
              <p class="font-semibold mb-2">Phiên bản:</p>
              <select id="variant-select" class="border border-gray-300 rounded-lg px-4 py-2 text-base w-full focus:outline-none focus:border-cyan-500">
                {%- for v in p.variants -%}
                  <option value="{{ v.id }}" {% unless v.available %}disabled{% endunless %}>
                    {{ v.title }} — {{ v.price | money }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endif -%}

          <div class="mb-6">
            <p class="font-semibold mb-2">Số lượng:</p>
            <div class="flex items-center border border-gray-300 rounded-lg w-32">
              <button onclick="updateQty(-1)" class="px-3 py-2 text-gray-600 hover:bg-gray-100"><i data-lucide="minus" class="w-4 h-4"></i></button>
              <input type="text" id="quantity-input" value="1" readonly class="w-full text-center font-semibold text-lg outline-none bg-transparent">
              <button onclick="updateQty(1)" class="px-3 py-2 text-gray-600 hover:bg-gray-100"><i data-lucide="plus" class="w-4 h-4"></i></button>
            </div>
          </div>

          <div class="flex flex-col gap-3 mb-8">
            <button
              id="add-to-cart-btn"
              onclick="handleAddToCart(false)"
              data-variant-id="{{ variant.id }}"
              class="w-full bg-white border-2 border-cyan-600 text-cyan-600 font-bold py-4 rounded-xl text-lg hover:bg-cyan-50 transition disabled:opacity-50"
            >
              THÊM VÀO GIỎ HÀNG
            </button>
            <button
              id="buy-now-btn"
              onclick="handleAddToCart(true)"
              data-variant-id="{{ variant.id }}"
              class="w-full bg-cyan-600 text-white font-bold py-4 rounded-xl text-lg hover:bg-cyan-700 transition shadow-lg flex justify-center items-center gap-2 disabled:opacity-50"
            >
              MUA NGAY <i data-lucide="chevron-right" class="w-5 h-5"></i>
            </button>
          </div>

          {%- comment -%} Product description excerpt {%- endcomment -%}
          {%- if p.description != blank -%}
            <div class="text-sm text-gray-600 border-t border-gray-200 pt-4">
              {{ p.description | truncate: 200 }}
            </div>
          {%- endif -%}

        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Toast notification {%- endcomment -%}
  <div
    id="cart-toast"
    class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-green-600 text-white px-6 py-3 rounded-full font-semibold shadow-lg z-50 transition-all duration-300 opacity-0 pointer-events-none flex items-center gap-2"
  >
    <i data-lucide="check-circle-2" class="w-5 h-5"></i>
    <span id="cart-toast-msg">Đã thêm vào giỏ hàng!</span>
  </div>

  {%- comment -%} Footer {%- endcomment -%}
  <footer class="bg-black text-gray-400 py-12 border-t border-gray-800">
    <div class="container mx-auto px-4 max-w-6xl grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
      <div>
        <a href="/" class="text-2xl font-black italic tracking-tighter text-white mb-4 block">{{ shop.name }}</a>
        <p>{{ shop.description | default: 'Sản phẩm công nghệ độc đáo, giao hàng toàn quốc.' }}</p>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4 uppercase">Liên kết nhanh</h4>
        <ul class="space-y-2">
          <li><a href="/collections/all" class="hover:text-white transition">Tất cả sản phẩm</a></li>
          <li><a href="/policies/shipping-policy" class="hover:text-white transition">Chính sách vận chuyển</a></li>
          <li><a href="/policies/refund-policy" class="hover:text-white transition">Chính sách đổi trả</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4 uppercase">Nhận thông báo</h4>
        <div class="flex">
          <input type="email" placeholder="Nhập email của bạn" class="bg-gray-900 border border-gray-700 px-4 py-2 w-full focus:outline-none focus:border-cyan-500 rounded-l-lg">
          <button class="bg-cyan-600 text-white px-4 py-2 font-bold hover:bg-cyan-700 rounded-r-lg">GỬI</button>
        </div>
      </div>
    </div>
  </footer>

  <script>
    lucide.createIcons();

    function updateQty(change) {
      const input = document.getElementById('quantity-input');
      const newVal = parseInt(input.value) + change;
      if (newVal >= 1) input.value = newVal;
    }

    function getCurrentVariantId() {
      const select = document.getElementById('variant-select');
      if (select) return select.value;
      return document.getElementById('add-to-cart-btn')?.dataset.variantId;
    }

    function showToast(msg, isError = false) {
      const toast = document.getElementById('cart-toast');
      document.getElementById('cart-toast-msg').textContent = msg;
      toast.classList.toggle('bg-green-600', !isError);
      toast.classList.toggle('bg-red-500', isError);
      toast.classList.remove('opacity-0', 'pointer-events-none');
      toast.classList.add('opacity-100');
      setTimeout(() => {
        toast.classList.remove('opacity-100');
        toast.classList.add('opacity-0', 'pointer-events-none');
      }, 3000);
    }

    async function handleAddToCart(buyNow = false) {
      const variantId = getCurrentVariantId();
      const quantity = parseInt(document.getElementById('quantity-input').value);

      if (!variantId || variantId === 'undefined' || variantId === '') {
        showToast('Vui lòng chọn phiên bản sản phẩm.', true);
        return;
      }

      const addBtn = document.getElementById('add-to-cart-btn');
      const buyBtn = document.getElementById('buy-now-btn');
      addBtn.disabled = true;
      buyBtn.disabled = true;

      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: parseInt(variantId), quantity })
        });

        const data = await response.json();

        if (!response.ok) {
          showToast(data.description || 'Có lỗi xảy ra, vui lòng thử lại.', true);
          return;
        }

        if (buyNow) {
          window.location.href = '/checkout';
        } else {
          showToast('Đã thêm vào giỏ hàng!');
          document.dispatchEvent(new CustomEvent('cart:update', { bubbles: true, detail: { itemCount: data.quantity } }));
        }
      } catch (err) {
        showToast('Không thể kết nối, vui lòng thử lại.', true);
      } finally {
        addBtn.disabled = false;
        buyBtn.disabled = false;
      }
    }
  </script>
</body>
</html>
