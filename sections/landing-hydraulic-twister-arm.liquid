{%- comment -%} Hero {%- endcomment -%}
<section class="twister-hero-shell relative w-full min-h-[600px] flex items-center py-16 md:py-24">
  <div class="absolute inset-0 overflow-hidden">
    <div class="twister-hero-product" aria-hidden="true">
      {%- if hero_image_url != blank -%}
        <svg
          class="twister-hero-product-media"
          viewBox="0 0 1000 1000"
          preserveAspectRatio="xMidYMid meet"
          role="presentation"
        >
          <defs>
            <filter id="{{ hero_filter_id }}" color-interpolation-filters="sRGB">
              <feColorMatrix in="SourceGraphic" type="luminanceToAlpha" result="bg-alpha"></feColorMatrix>
              <feComponentTransfer in="bg-alpha" result="cutout-alpha">
                <feFuncA type="table" tableValues="1 1 1 1 1 1 0.98 0.94 0.86 0.58 0.16 0"></feFuncA>
              </feComponentTransfer>
              <feComposite in="SourceGraphic" in2="cutout-alpha" operator="in"></feComposite>
            </filter>
          </defs>
          <image
            href="{{ hero_image_url }}"
            width="1000"
            height="1000"
            preserveAspectRatio="xMidYMid meet"
            filter="url(#{{ hero_filter_id }})"
          ></image>
        </svg>
      {%- else -%}
        <img
          src="https://placehold.co/1200x1200/111827/f9fafb?text=[Product+Image]"
          class="twister-hero-product-media"
          alt=""
          loading="eager"
        >
      {%- endif -%}
    </div>
    <div class="twister-hero-overlay"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 max-w-6xl">
    <div class="max-w-3xl mx-auto md:mx-0 text-center md:text-left">
      <div class="inline-flex items-center gap-2 bg-orange-900/50 border border-orange-700 text-orange-300 text-xs font-bold px-4 py-1.5 rounded-full mb-6 uppercase tracking-widest mx-auto md:mx-0">
        <i data-lucide="zap" class="w-3.5 h-3.5"></i> Adjustable Hydraulic Resistance
      </div>

      <h1 class="text-4xl md:text-6xl font-black uppercase gradient-text leading-tight mb-6">
        Build Power. <br> Train Anywhere.
      </h1>
      <p class="text-xl md:text-2xl font-light text-gray-300 mb-8 max-w-lg mx-auto md:mx-0">
        {{ p.title }} — Target your arms, chest, forearms, biceps & core with one versatile tool.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center md:justify-start">
        <button
          onclick="document.getElementById('buy-section').scrollIntoView({ behavior: 'smooth' })"
          class="glow-btn bg-gradient-to-r from-orange-500 to-red-600 hover:from-orange-400 hover:to-red-500 text-white font-bold py-4 px-10 rounded-full text-lg transition transform hover:scale-105"
        >
          ORDER NOW
        </button>
        <button
          onclick="document.getElementById('features').scrollIntoView({ behavior: 'smooth' })"
          class="border border-white/40 text-white font-semibold py-4 px-8 rounded-full text-lg hover:bg-white/10 transition"
        >
          Learn More
        </button>
      </div>

      <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 sm:gap-6 mt-8 text-sm text-gray-400">
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-yellow-400 shrink-0 fill-current" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M11.48 3.5a.56.56 0 0 1 1.04 0l2.12 5.11a.56.56 0 0 0 .47.34l5.52.44c.5.04.7.66.32.98l-4.2 3.6a.56.56 0 0 0-.18.56l1.28 5.39a.56.56 0 0 1-.84.61L12.3 17.7a.56.56 0 0 0-.58 0l-4.74 2.88a.56.56 0 0 1-.84-.61l1.28-5.39a.56.56 0 0 0-.18-.56l-4.2-3.6a.56.56 0 0 1 .32-.98l5.52-.44a.56.56 0 0 0 .47-.34z"></path>
          </svg>
          <span>4.9/5 (856 reviews)</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-orange-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
          <span>3,000+ customers</span>
        </div>
      </div>
    </div>
  </div>
</section>

