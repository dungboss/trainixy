<script>
  lucide.createIcons();

  function updateQty(change) {
    const input = document.getElementById('quantity-input');
    const newVal = parseInt(input.value) + change;
    if (newVal >= 1) input.value = newVal;
  }

  function getCurrentVariantId() {
    const select = document.getElementById('variant-select');
    if (select) return select.value;
    return document.getElementById('add-to-cart-btn')?.dataset.variantId;
  }

  function showToast(msg, isError = false) {
    const toast = document.getElementById('cart-toast');
    document.getElementById('cart-toast-msg').textContent = msg;
    toast.classList.toggle('bg-green-600', !isError);
    toast.classList.toggle('bg-red-500', isError);
    toast.classList.remove('opacity-0', 'pointer-events-none');
    toast.classList.add('opacity-100');
    setTimeout(() => {
      toast.classList.remove('opacity-100');
      toast.classList.add('opacity-0', 'pointer-events-none');
    }, 3000);
  }

  async function handleAddToCart(buyNow = false) {
    const variantId = getCurrentVariantId();
    const quantity = parseInt(document.getElementById('quantity-input').value);

    if (!variantId || variantId === 'undefined' || variantId === '') {
      showToast('Please select a product variant.', true);
      return;
    }

    const addBtn = document.getElementById('add-to-cart-btn');
    const buyBtn = document.getElementById('buy-now-btn');
    addBtn.disabled = true;
    buyBtn.disabled = true;

    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId), quantity })
      });

      const data = await response.json();

      if (!response.ok) {
        showToast(data.description || 'Something went wrong. Please try again.', true);
        return;
      }

      if (buyNow) {
        window.location.href = '/checkout';
      } else {
        showToast('Added to cart!');
        document.dispatchEvent(new CustomEvent('cart:update', { bubbles: true, detail: { itemCount: data.quantity } }));
      }
    } catch (err) {
      showToast('Connection error. Please try again.', true);
    } finally {
      addBtn.disabled = false;
      buyBtn.disabled = false;
    }
  }

  (function initBeforeAfterCarousel() {
    const track = document.querySelector('[data-before-after-track]');
    if (!track) return;

    const originalCards = Array.from(track.querySelectorAll('[data-before-after-card]'));
    if (originalCards.length < 2) return;

    const prependFragment = document.createDocumentFragment();
    const appendFragment = document.createDocumentFragment();

    originalCards.forEach((card) => {
      const prependClone = card.cloneNode(true);
      prependClone.dataset.beforeAfterClone = 'true';
      prependClone.setAttribute('aria-hidden', 'true');
      prependFragment.appendChild(prependClone);

      const appendClone = card.cloneNode(true);
      appendClone.dataset.beforeAfterClone = 'true';
      appendClone.setAttribute('aria-hidden', 'true');
      appendFragment.appendChild(appendClone);
    });

    track.prepend(prependFragment);
    track.append(appendFragment);

    const originalCount = originalCards.length;
    let currentIndex = originalCount;
    let autoTimer = null;
    let isDragging = false;
    let dragMode = null;
    let dragStartX = 0;
    let dragStartScrollLeft = 0;
    let scrollTimer = null;

    function allCards() {
      return Array.from(track.children);
    }

    function cardOffsets() {
      return allCards().map((card) => card.offsetLeft - track.offsetLeft);
    }

    function scrollToIndex(index, behavior = 'smooth') {
      const offsets = cardOffsets();
      const clampedIndex = Math.max(0, Math.min(index, offsets.length - 1));
      currentIndex = clampedIndex;
      track.scrollTo({
        left: offsets[clampedIndex] ?? 0,
        behavior
      });
    }

    function nearestIndex() {
      const scrollLeft = track.scrollLeft;
      const offsets = cardOffsets();
      let nearest = 0;
      let minDistance = Number.POSITIVE_INFINITY;

      offsets.forEach((offset, index) => {
        const distance = Math.abs(offset - scrollLeft);
        if (distance < minDistance) {
          minDistance = distance;
          nearest = index;
        }
      });

      return nearest;
    }

    function normalizeIndex(index) {
      if (index < originalCount) return index + originalCount;
      if (index >= originalCount * 2) return index - originalCount;
      return index;
    }

    function syncLoopPosition() {
      const normalizedIndex = normalizeIndex(currentIndex);
      if (normalizedIndex === currentIndex) return;

      currentIndex = normalizedIndex;
      const offsets = cardOffsets();
      track.scrollTo({
        left: offsets[normalizedIndex] ?? 0,
        behavior: 'auto'
      });
    }

    function stopAuto() {
      if (autoTimer) {
        window.clearInterval(autoTimer);
        autoTimer = null;
      }
    }

    function startAuto() {
      stopAuto();
      autoTimer = window.setInterval(() => {
        currentIndex = normalizeIndex(currentIndex);
        scrollToIndex(currentIndex + 1);
      }, 3000);
    }

    function beginDrag(clientX, mode) {
      isDragging = true;
      dragMode = mode;
      dragStartX = clientX;
      dragStartScrollLeft = track.scrollLeft;
      track.classList.add('is-dragging');
      stopAuto();
    }

    function updateDrag(clientX) {
      const deltaX = clientX - dragStartX;
      track.scrollLeft = dragStartScrollLeft - deltaX;
    }

    function endDrag() {
      if (!isDragging) return;
      isDragging = false;
      dragMode = null;
      track.classList.remove('is-dragging');
      currentIndex = normalizeIndex(nearestIndex());
      scrollToIndex(currentIndex);
      startAuto();
    }

    track.addEventListener('mousedown', (event) => {
      if (event.button !== 0) return;
      event.preventDefault();
      beginDrag(event.clientX, 'mouse');
    });

    window.addEventListener('mousemove', (event) => {
      if (!isDragging || dragMode !== 'mouse') return;
      event.preventDefault();
      updateDrag(event.clientX);
    }, { passive: false });

    track.addEventListener('dragstart', (event) => event.preventDefault());
    window.addEventListener('mouseup', () => {
      if (dragMode !== 'mouse') return;
      endDrag();
    });

    track.addEventListener('touchstart', (event) => {
      const touch = event.touches[0];
      if (!touch) return;
      beginDrag(touch.clientX, 'touch');
    }, { passive: true });

    track.addEventListener('touchmove', (event) => {
      if (!isDragging || dragMode !== 'touch') return;
      const touch = event.touches[0];
      if (!touch) return;
      if (event.cancelable) event.preventDefault();
      updateDrag(touch.clientX);
    }, { passive: false });

    window.addEventListener('touchend', () => {
      if (dragMode !== 'touch') return;
      endDrag();
    }, { passive: true });
    window.addEventListener('touchcancel', () => {
      if (dragMode !== 'touch') return;
      endDrag();
    }, { passive: true });

    track.addEventListener('scroll', () => {
      if (isDragging) return;
      window.clearTimeout(scrollTimer);
      scrollTimer = window.setTimeout(() => {
        currentIndex = normalizeIndex(nearestIndex());
        syncLoopPosition();
      }, 120);
    }, { passive: true });

    window.addEventListener('resize', () => {
      currentIndex = normalizeIndex(currentIndex);
      scrollToIndex(currentIndex, 'auto');
    });

    requestAnimationFrame(() => {
      scrollToIndex(originalCount, 'auto');
      startAuto();
    });
  })();
</script>

