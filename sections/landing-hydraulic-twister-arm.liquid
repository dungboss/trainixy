{%- comment -%}
  Section: Adjustable Hydraulic Power Twister landing page
  Used with layout/landing.liquid and templates/product.landing-hydraulic-twister-arm.json
{%- endcomment -%}

<style>
  /* Gradient text — fix Safari / iOS */
  .gradient-text {
    background: linear-gradient(to right, #f97316, #ef4444);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .glow-btn { box-shadow: 0 0 20px rgba(249, 115, 22, 0.45); }
  .glow-btn:hover { box-shadow: 0 0 32px rgba(249, 115, 22, 0.7); }

  .twister-hero-shell {
    background:
      radial-gradient(circle at 78% 40%, rgba(249, 115, 22, 0.2), transparent 22rem),
      linear-gradient(90deg, #020617 0%, #020617 36%, rgba(2, 6, 23, 0.88) 56%, rgba(2, 6, 23, 0.26) 82%, rgba(2, 6, 23, 0.08) 100%);
    align-items: flex-start;
    min-height: auto;
    padding-bottom: 4rem;
  }

  .twister-hero-background-layer {
    display: none;
  }

  .twister-hero-background {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 72% center;
    transform: scale(1.04);
  }

  .twister-hero-mobile-card {
    display: block;
    max-width: min(100%, 24rem);
    margin: 0 auto 1.75rem;
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(249, 115, 22, 0.22);
    box-shadow:
      0 18px 44px rgba(0, 0, 0, 0.36),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
  }

  .twister-hero-mobile-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .twister-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(2, 6, 23, 0.98) 0%, rgba(2, 6, 23, 0.95) 42%, rgba(2, 6, 23, 0.82) 58%, rgba(2, 6, 23, 0.28) 80%, rgba(2, 6, 23, 0.92) 100%);
  }

  .twister-compare-card {
    border-radius: 1.25rem;
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 14px 32px rgba(15, 23, 42, 0.07);
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    height: 100%;
  }

  .twister-compare-problem {
    background: #949494;
    display: flex;
    flex-direction: column;
  }

  .twister-compare-solution {
    background: linear-gradient(135deg, #ffd54f 0%, #ffbf00 100%);
    min-height: 170px;
  }

  .twister-compare-title {
    min-height: 120px;
  }

  .twister-compare-solution-copy {
    min-height: 116px;
  }

  .twister-compare-photo {
    width: 100%;
    height: 210px;
    object-fit: cover;
    border-radius: 0.875rem;
    filter: grayscale(100%);
  }

  .twister-compare-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .twister-compare-track::-webkit-scrollbar {
    display: none;
  }

  .twister-before-after-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc(100% - 0.25rem);
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  .twister-before-after-track::-webkit-scrollbar {
    display: none;
  }

  .twister-before-after-track.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    scroll-snap-type: none;
  }

  .twister-before-after-card {
    background: #000;
    border: 1.5px solid #f97316;
    border-radius: 0.875rem;
    padding: 0.625rem;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.24);
    user-select: none;
  }

  .twister-before-after-image {
    width: 100%;
    display: block;
    object-fit: cover;
    background: #1f2937;
    border-radius: 0.35rem;
    aspect-ratio: 16 / 6.4;
    pointer-events: none;
    -webkit-user-drag: none;
  }

  .twister-table-wrap {
    border: 1px solid rgba(249, 115, 22, 0.18);
    border-radius: 1.25rem;
    overflow: hidden;
    min-width: 0;
    background: #ffffff;
    box-shadow:
      0 24px 60px rgba(2, 6, 23, 0.24),
      0 0 0 1px rgba(255, 255, 255, 0.72) inset;
  }

  .twister-table-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(0, 0.78fr) minmax(0, 0.78fr);
  }

  .twister-table-head-spacer {
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    border-right: 1px solid rgba(15, 23, 42, 0.1);
    border-bottom: 1px solid rgba(15, 23, 42, 0.1);
    display: flex;
    align-items: flex-end;
    padding: 0.75rem 0.65rem;
  }

  .twister-table-feature-heading {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.1;
    font-weight: 900;
    text-transform: uppercase;
    color: #0f172a;
  }

  .twister-table-head-cell {
    padding: 0.75rem 0.45rem 0.7rem;
    border-bottom: 1px solid rgba(15, 23, 42, 0.1);
    text-align: center;
  }

  .twister-table-head-cell + .twister-table-head-cell {
    border-left: 1px solid rgba(15, 23, 42, 0.1);
  }

  .twister-table-head-cell--primary,
  .twister-table-cell--primary {
    background: linear-gradient(180deg, #fff7ed, #ffedd5);
  }

  .twister-table-head-cell--secondary,
  .twister-table-cell--secondary {
    background: linear-gradient(180deg, #f8fafc, #f1f5f9);
  }

  .twister-table-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.45rem;
    padding: 0.26rem 0.5rem;
    border-radius: 999px;
    font-size: 0.54rem;
    line-height: 1;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
    background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
    box-shadow: 0 8px 18px rgba(249, 115, 22, 0.22);
  }

  .twister-table-pill--secondary {
    background: #e2e8f0;
    color: #334155;
    box-shadow: none;
  }

  .twister-table-product-image {
    width: 100%;
    max-width: 3.5rem;
    height: auto;
    object-fit: contain;
    margin: 0 auto 0.45rem;
  }

  .twister-table-image-placeholder {
    width: 100%;
    max-width: 3.5rem;
    aspect-ratio: 1;
    margin: 0 auto 0.45rem;
    border-radius: 0.9rem;
    border: 1px dashed rgba(249, 115, 22, 0.22);
    background:
      radial-gradient(circle at 30% 30%, rgba(249, 115, 22, 0.12), transparent 35%),
      linear-gradient(135deg, #ffffff, #f8fafc);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #64748b;
  }

  .twister-table-column-title {
    font-size: 0.78rem;
    line-height: 1.15;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0;
    word-break: break-word;
    color: #0f172a;
  }

  .twister-table-column-subtitle {
    margin-top: 0.35rem;
    font-size: 0.68rem;
    line-height: 1.35;
    color: #64748b;
  }

  .twister-table-row + .twister-table-row {
    border-top: 1px solid rgba(15, 23, 42, 0.1);
  }

  .twister-table-feature-cell {
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    padding: 0.9rem 0.65rem;
    border-right: 1px solid rgba(15, 23, 42, 0.1);
  }

  .twister-table-feature-title {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.18;
    font-weight: 900;
    color: #0f172a;
  }

  .twister-table-feature-subtitle {
    margin-top: 0.28rem;
    font-size: 0.68rem;
    line-height: 1.35;
    color: #64748b;
  }

  .twister-table-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.35rem;
  }

  .twister-table-cell + .twister-table-cell {
    border-left: 1px solid rgba(15, 23, 42, 0.1);
  }

  .twister-table-status {
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.12);
  }

  .twister-table-status svg {
    width: 0.86rem;
    height: 0.86rem;
  }

  .twister-table-status--check {
    background: #fb6a4a;
    color: #ffffff;
  }

  .twister-table-status--cross {
    background: #64748b;
    color: #ffffff;
  }

  .twister-table-status--dash {
    width: 2.5rem;
    height: 2px;
    border-radius: 999px;
    background: rgba(100, 116, 139, 0.42);
    box-shadow: none;
  }

  @media (min-width: 768px) {
    .twister-table-wrap {
      min-width: 720px;
    }

    .twister-table-grid {
      grid-template-columns: minmax(220px, 1.25fr) minmax(210px, 0.92fr) minmax(210px, 0.92fr);
    }

    .twister-table-head-spacer {
      padding: 1rem 1rem 0.85rem;
    }

    .twister-table-feature-heading {
      font-size: 1.15rem;
      line-height: 1.15;
    }

    .twister-table-head-cell {
      padding: 1rem 1rem 0.85rem;
    }

    .twister-table-pill {
      margin-bottom: 0.75rem;
      padding: 0.36rem 0.72rem;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
    }

    .twister-table-product-image,
    .twister-table-image-placeholder {
      max-width: 6rem;
      margin-bottom: 0.9rem;
    }

    .twister-table-image-placeholder {
      border-radius: 1.25rem;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
    }

    .twister-table-column-title {
      font-size: 1.15rem;
    }

    .twister-table-column-subtitle {
      font-size: 0.88rem;
      line-height: 1.45;
    }

    .twister-table-feature-cell {
      padding: 1.15rem 1rem;
    }

    .twister-table-feature-title {
      font-size: 1.08rem;
      line-height: 1.2;
    }

    .twister-table-feature-subtitle {
      font-size: 0.92rem;
      line-height: 1.45;
    }

    .twister-table-cell {
      padding: 1rem;
    }

    .twister-table-status {
      width: 2.2rem;
      height: 2.2rem;
    }

    .twister-table-status svg {
      width: 1.1rem;
      height: 1.1rem;
    }

    .twister-hero-shell {
      align-items: center;
      min-height: 600px;
      padding-bottom: 6rem;
    }

    .twister-hero-background-layer {
      display: block;
    }

    .twister-hero-background {
      object-position: center;
    }

    .twister-hero-mobile-card {
      display: none;
    }

    .twister-hero-overlay {
      background: linear-gradient(90deg, rgba(2, 6, 23, 0.98) 0%, rgba(2, 6, 23, 0.94) 35%, rgba(2, 6, 23, 0.58) 56%, rgba(2, 6, 23, 0.08) 78%, rgba(2, 6, 23, 0) 100%);
    }

    .twister-compare-photo {
      height: 220px;
    }

    .twister-compare-title {
      min-height: 132px;
    }

    .twister-compare-solution-copy {
      min-height: 124px;
    }

    .twister-before-after-track {
      grid-auto-columns: calc((100% - 1.5rem) / 2);
    }

    .twister-before-after-card {
      padding: 0.75rem;
    }
  }
</style>

{%- liquid
  assign p = product
  assign variant = product.selected_or_first_available_variant
  assign imgs = product.images

  if section.settings.hero_background_image != blank
    assign hero_background_url = section.settings.hero_background_image | image_url: width: 2000
  else
    assign hero_background_url = 'hydraulic-twister-background.png' | asset_url
  endif

  if section.settings.hero_mobile_image != blank
    assign hero_mobile_image_url = section.settings.hero_mobile_image | image_url: width: 1200
  else
    assign hero_mobile_image_url = 'hydraulic-twister-mobile-hero.png' | asset_url
  endif

  assign announcement_text = section.settings.announcement_text | default: '💪 LIMITED OFFER – FREE SHIPPING NATIONWIDE – WHILE STOCKS LAST 💪'
  assign nav_products_label = section.settings.nav_products_label | default: 'Products'
  assign nav_features_label = section.settings.nav_features_label | default: 'Features'
  assign nav_buy_label = section.settings.nav_buy_label | default: 'Buy Now'
  assign hero_badge_text = section.settings.hero_badge_text | default: 'Adjustable Hydraulic Resistance'
  assign hero_title = section.settings.hero_title | default: 'Build Power.||Train Anywhere.'
  assign hero_subtitle = section.settings.hero_subtitle | default: 'Target your arms, chest, forearms, biceps & core with one versatile tool.'
  assign primary_button_label = section.settings.primary_button_label | default: 'ORDER NOW'
  assign secondary_button_label = section.settings.secondary_button_label | default: 'Learn More'
  assign hero_rating_text = section.settings.hero_rating_text | default: '4.9/5 (856 reviews)'
  assign hero_social_text = section.settings.hero_social_text | default: '3,000+ customers'
  assign trust_shipping_text = section.settings.trust_shipping_text | default: 'NATIONWIDE SHIPPING'
  assign trust_warranty_text = section.settings.trust_warranty_text | default: '12-MONTH WARRANTY'
  assign trust_returns_text = section.settings.trust_returns_text | default: '30-DAY FREE RETURNS'
  assign features_heading = section.settings.features_heading | default: 'Key Features'
  assign features_data = section.settings.features_data | default: 'sliders|Adjustable Resistance|Resistance Range: 22 - 440 lbs||activity|Multi-Muscle Training|Chest, Shoulders, Arms, Forearms, and more||shield|Heavy-Duty Carbon Steel|Tested for 10000 cycles||monitor|See Your Progress In Real-Time|The clear LCD counter tracks your reps||hand|Ergonomic Grip|Non-slip foam handles||dumbbell|Compact & Portable|Train at home or the gym'
  assign specs_heading_accent = section.settings.specs_heading_accent | default: 'Technical'
  assign specs_heading_text = section.settings.specs_heading_text | default: 'Specifications'
  assign specs_data = section.settings.specs_data | default: '440 Lbs|Max Resistance||6+|Muscle Groups||Steel|Heavy-duty Frame||1 Tool|Full Upper Body'
  assign guarantee_text = section.settings.guarantee_text | default: 'FREE 30-DAY RETURNS — NO QUESTIONS ASKED'
  assign before_after_label = section.settings.before_after_label | default: 'Before & After'
  assign before_after_heading = section.settings.before_after_heading | default: 'See the Visual Difference'
  assign before_after_images_data = section.settings.before_after_images_data | default: 'https://cdn.shopify.com/s/files/1/0849/9606/3537/files/20260316-p3-4-pc.png||https://cdn.shopify.com/s/files/1/0849/9606/3537/files/20260316-p3-1-pc.png||https://cdn.shopify.com/s/files/1/0849/9606/3537/files/20260316-p3-2-pc.png||https://cdn.shopify.com/s/files/1/0849/9606/3537/files/20260316-p3-3-pc.png'
  assign before_after_images = before_after_images_data | newline_to_br | replace: '<br />', '||' | replace: '<br>', '||' | split: '||'
  assign compare_label = section.settings.compare_label | default: 'Why Upgrade'
  assign compare_heading = section.settings.compare_heading | default: 'Why Old Home Workout Gear Falls Short'
  assign compare_subheading = section.settings.compare_subheading | default: 'Switch to the Twister Arm Exerciser'
  assign compare_items_data = section.settings.compare_items_data | default: 'https://cdn.myshopage.com/af890d5a-9317-4602-a938-bf46d7e33f00/w400.jpg##Your home gym ends up cluttered with separate dumbbells and plates just to train your chest and arms.##Train your arms, chest, forearms and core with one compact tool instead of a pile of bulky gear.||https://cdn.myshopage.com/039bce89-25cb-4e30-5744-28d0686f2900/w400.jpg##Old spring-based twisters can snap back hard and give you almost no control.##The hydraulic resistance stays smooth and controlled, helping reduce harsh snap-back during every rep.||https://cdn.myshopage.com/2180b2a1-8bbf-4fae-e958-697de033d400/w400.jpg##It is easy to lose count of reps or wonder whether you are actually making progress.##The built-in LCD counter tracks each rep so you can focus on form and progression.||https://cdn.myshopage.com/083e8d3a-551e-4b51-d6fc-1b57ac4eaf00/w400.jpg##Most home equipment is either too easy or too intense, which slows down progress.##A quick turn of the knob lets you dial the resistance for beginners, daily training or tougher sets.'
  assign comparison_table_label = section.settings.comparison_table_label | default: 'Comparison'
  assign comparison_table_heading = section.settings.comparison_table_heading | default: 'See How It Stacks Up'
  assign comparison_table_subheading = section.settings.comparison_table_subheading
  assign comparison_table_feature_heading = section.settings.comparison_table_feature_heading | default: 'Features'
  assign comparison_table_left_badge = section.settings.comparison_table_left_badge
  assign comparison_table_left_title = section.settings.comparison_table_left_title | default: 'Power Twister'
  assign comparison_table_left_subtitle = section.settings.comparison_table_left_subtitle
  assign comparison_table_right_badge = section.settings.comparison_table_right_badge
  assign comparison_table_right_title = section.settings.comparison_table_right_title | default: 'Generic Alternatives'
  assign comparison_table_right_subtitle = section.settings.comparison_table_right_subtitle
  assign footer_description = section.settings.footer_description | default: shop.description | default: 'Premium fitness equipment, delivered nationwide.'
  assign footer_links_heading = section.settings.footer_links_heading | default: 'Quick Links'
  assign footer_link_1_label = section.settings.footer_link_1_label | default: 'All Products'
  assign footer_link_1_url = section.settings.footer_link_1_url | default: '/collections/all'
  assign footer_link_2_label = section.settings.footer_link_2_label | default: 'Shipping Policy'
  assign footer_link_2_url = section.settings.footer_link_2_url | default: '/policies/shipping-policy'
  assign footer_link_3_label = section.settings.footer_link_3_label | default: 'Return Policy'
  assign footer_link_3_url = section.settings.footer_link_3_url | default: '/policies/refund-policy'
  assign footer_newsletter_heading = section.settings.footer_newsletter_heading | default: 'Stay Updated'
  assign footer_newsletter_placeholder = section.settings.footer_newsletter_placeholder | default: 'Enter your email'
  assign footer_newsletter_button = section.settings.footer_newsletter_button | default: 'GO'
  assign compare_items = compare_items_data | newline_to_br | replace: '<br />', '||' | replace: '<br>', '||' | split: '||'
-%}

{%- comment -%} Announcement bar {%- endcomment -%}
<div class="bg-orange-600 text-white text-center py-2 text-sm font-semibold tracking-wide">
  {{ announcement_text }}
</div>

{%- comment -%} Header {%- endcomment -%}
<header class="sticky top-0 z-50 bg-black/95 border-b border-gray-800 py-4 px-4 md:px-8 flex justify-between items-center">
  <div class="flex items-center gap-4">
    <i data-lucide="menu" class="w-6 h-6 cursor-pointer md:hidden"></i>
    <a href="/" class="inline-flex items-center">
      <img src="{{ 'trainixy-logo-white.png' | asset_url }}" class="h-10 w-auto md:h-12" alt="{{ shop.name }}" loading="eager">
    </a>
  </div>
  <nav class="hidden md:flex gap-6 text-sm font-medium">
    <a href="/collections/all" class="hover:text-orange-400 transition">{{ nav_products_label }}</a>
    <a href="#features" class="hover:text-orange-400 transition">{{ nav_features_label }}</a>
    <a href="#buy-section" class="hover:text-orange-400 transition">{{ nav_buy_label }}</a>
  </nav>
  <a href="/cart"><i data-lucide="shopping-cart" class="w-6 h-6 cursor-pointer hover:text-orange-400 transition"></i></a>
</header>

{%- comment -%} Hero {%- endcomment -%}
<section class="twister-hero-shell relative w-full min-h-[600px] flex items-center py-16 md:py-24">
  <div class="twister-hero-background-layer absolute inset-0 overflow-hidden">
    <img
      src="{{ hero_background_url }}"
      class="twister-hero-background"
      alt=""
      loading="eager"
      aria-hidden="true"
    >
    <div class="twister-hero-overlay"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 max-w-6xl">
    <div class="max-w-3xl mx-auto md:mx-0 text-center md:text-left">
      <div class="inline-flex items-center gap-2 bg-orange-900/50 border border-orange-700 text-orange-300 text-xs font-bold px-4 py-1.5 rounded-full mb-6 uppercase tracking-widest mx-auto md:mx-0">
        <i data-lucide="zap" class="w-3.5 h-3.5"></i> {{ hero_badge_text }}
      </div>

      <h1 class="text-4xl md:text-6xl font-black uppercase gradient-text leading-tight mb-6">
        {{ hero_title | newline_to_br | replace: '||', '<br>' }}
      </h1>
      <div class="twister-hero-mobile-card">
        <img
          src="{{ hero_mobile_image_url }}"
          class="twister-hero-mobile-image"
          alt="{{ p.title }}"
          loading="eager"
        >
      </div>
      <p class="text-xl md:text-2xl font-light text-gray-300 mb-8 max-w-lg mx-auto md:mx-0">
        {{ p.title }} — {{ hero_subtitle }}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center md:justify-start">
        <button
          onclick="document.getElementById('buy-section').scrollIntoView({ behavior: 'smooth' })"
        class="glow-btn bg-gradient-to-r from-orange-500 to-red-600 hover:from-orange-400 hover:to-red-500 text-white font-bold py-4 px-10 rounded-full text-lg transition transform hover:scale-105"
      >
        {{ primary_button_label }}
      </button>
        <button
          onclick="document.getElementById('features').scrollIntoView({ behavior: 'smooth' })"
        class="border border-white/40 text-white font-semibold py-4 px-8 rounded-full text-lg hover:bg-white/10 transition"
      >
        {{ secondary_button_label }}
      </button>
      </div>

      <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 sm:gap-6 mt-8 text-sm text-gray-400">
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-yellow-400 shrink-0 fill-current" viewBox="0 0 24 24" aria-hidden="true">
