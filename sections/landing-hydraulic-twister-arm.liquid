{%- comment -%} Features {%- endcomment -%}
<section id="features" class="py-16 container mx-auto px-4">
  <div class="text-center mb-12">
    <h2 class="text-3xl font-bold uppercase mb-4">Key Features</h2>
    <div class="w-24 h-1 bg-orange-500 mx-auto"></div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center max-w-5xl mx-auto">
    <div>
      {%- if imgs[1] -%}
        <img src="{{ imgs[1] | image_url: width: 600 }}" class="w-full rounded-xl" alt="Features">
      {%- else -%}
        <img src="https://placehold.co/600x600/111827/374151?text=[Feature+Image]" class="w-full rounded-xl" alt="Features">
      {%- endif -%}
    </div>
    <div class="grid grid-cols-2 gap-4">
      {%- assign features = 'sliders|Adjustable Resistance|Resistance Range: 22 - 440 lbs||activity|Multi-Muscle Training|Chest, Shoulders, Arms, Forearms,…||shield|Heavy-Duty Carbon Steel|Tested For 10000 cycles||monitor|See Your Progress In Real-Time|The clear LCD counter tracks your reps||hand|Ergonomic Grip|Non-slip foam handles||dumbbell|Compact & Portable|Train at home or the gym' | split: '||' -%}
      {%- for feat in features -%}
        {%- assign feat_parts = feat | split: '|' -%}
        <div class="bg-neutral-900 p-6 rounded-xl border border-neutral-800 text-center hover:border-orange-500 transition cursor-pointer group">
          <div class="w-12 h-12 mx-auto bg-neutral-800 rounded-full flex items-center justify-center mb-4 group-hover:bg-orange-900 transition">
            <i data-lucide="{{ feat_parts[0] }}" class="w-6 h-6 text-orange-400"></i>
          </div>
          <h3 class="font-bold text-sm">{{ feat_parts[1] }}</h3>
          <p class="text-gray-400 text-xs mt-1">{{ feat_parts[2] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

