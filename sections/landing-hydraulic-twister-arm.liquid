{%- comment -%}
  Section: Adjustable Hydraulic Power Twister landing page
  Used with layout/landing.liquid and templates/product.landing-hydraulic-twister-arm.json
{%- endcomment -%}

<style>
  /* Gradient text — fix Safari / iOS */
  .gradient-text {
    background: linear-gradient(to right, #f97316, #ef4444);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .glow-btn { box-shadow: 0 0 20px rgba(249, 115, 22, 0.45); }
  .glow-btn:hover { box-shadow: 0 0 32px rgba(249, 115, 22, 0.7); }

  .twister-hero-shell {
    background:
      radial-gradient(circle at 78% 40%, rgba(249, 115, 22, 0.2), transparent 22rem),
      linear-gradient(90deg, #020617 0%, #020617 36%, rgba(2, 6, 23, 0.88) 56%, rgba(2, 6, 23, 0.26) 82%, rgba(2, 6, 23, 0.08) 100%);
    align-items: flex-start;
    min-height: 840px;
    padding-bottom: clamp(20rem, 62vw, 28rem);
  }

  .twister-hero-product {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 24rem 0 0.5rem;
    pointer-events: none;
  }

  .twister-hero-product::before {
    content: '';
    position: absolute;
    width: min(100vw, 24rem);
    aspect-ratio: 1 / 1;
    border-radius: 999px;
    background:
      radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.34) 0%, rgba(255, 255, 255, 0.18) 18%, rgba(249, 115, 22, 0.16) 38%, rgba(15, 23, 42, 0) 72%);
    filter: blur(10px);
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
  }

  .twister-hero-product-media {
    position: relative;
    z-index: 1;
    width: min(92vw, 25rem);
    max-height: none;
    filter:
      blur(0.75px)
      brightness(0.96)
      contrast(1.06)
      drop-shadow(0 20px 32px rgba(0, 0, 0, 0.24))
      drop-shadow(0 34px 64px rgba(0, 0, 0, 0.42));
    opacity: 0.84;
    overflow: visible;
    transform: translate(6%, 1.5rem) scale(1.15);
    transform-origin: bottom center;
  }

  .twister-hero-product-media image {
    width: 100%;
    height: 100%;
  }

  .twister-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(2, 6, 23, 0.98) 0%, rgba(2, 6, 23, 0.95) 42%, rgba(2, 6, 23, 0.82) 58%, rgba(2, 6, 23, 0.28) 80%, rgba(2, 6, 23, 0.92) 100%);
  }

  .twister-compare-card {
    border-radius: 1.25rem;
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 14px 32px rgba(15, 23, 42, 0.07);
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    height: 100%;
  }

  .twister-compare-problem {
    background: #949494;
    display: flex;
    flex-direction: column;
  }

  .twister-compare-solution {
    background: linear-gradient(135deg, #ffd54f 0%, #ffbf00 100%);
    min-height: 170px;
  }

  .twister-compare-title {
    min-height: 120px;
  }

  .twister-compare-solution-copy {
    min-height: 116px;
  }

  .twister-compare-photo {
    width: 100%;
    height: 210px;
    object-fit: cover;
    border-radius: 0.875rem;
    filter: grayscale(100%);
  }

  .twister-compare-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .twister-compare-track::-webkit-scrollbar {
    display: none;
  }

  .twister-before-after-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc(100% - 0.25rem);
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  .twister-before-after-track::-webkit-scrollbar {
    display: none;
  }

  .twister-before-after-track.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    scroll-snap-type: none;
  }

  .twister-before-after-card {
    background: #000;
    border: 1.5px solid #f97316;
    border-radius: 0.875rem;
    padding: 0.625rem;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.24);
    user-select: none;
  }

  .twister-before-after-image {
    width: 100%;
    display: block;
    object-fit: cover;
    background: #1f2937;
    border-radius: 0.35rem;
    aspect-ratio: 16 / 6.4;
    pointer-events: none;
    -webkit-user-drag: none;
  }

  @media (min-width: 768px) {
    .twister-hero-shell {
      align-items: center;
      min-height: 600px;
      padding-bottom: 6rem;
    }

    .twister-hero-product {
      align-items: center;
      justify-content: flex-end;
      padding: 1rem 4vw 1rem 44%;
    }

    .twister-hero-product::before {
      width: min(40vw, 42rem);
      left: auto;
      right: clamp(2rem, 7vw, 6rem);
      top: 50%;
      bottom: auto;
      transform: translateY(-50%);
    }

    .twister-hero-product-media {
      width: min(48vw, 860px);
      max-height: 92%;
      filter:
        drop-shadow(0 20px 32px rgba(0, 0, 0, 0.24))
        drop-shadow(0 34px 64px rgba(0, 0, 0, 0.42));
      opacity: 1;
      transform: none;
    }

    .twister-hero-overlay {
      background: linear-gradient(90deg, rgba(2, 6, 23, 0.98) 0%, rgba(2, 6, 23, 0.94) 35%, rgba(2, 6, 23, 0.58) 56%, rgba(2, 6, 23, 0.08) 78%, rgba(2, 6, 23, 0) 100%);
    }

    .twister-compare-photo {
      height: 220px;
    }

    .twister-compare-title {
      min-height: 132px;
    }

    .twister-compare-solution-copy {
      min-height: 124px;
    }

    .twister-before-after-track {
      grid-auto-columns: calc((100% - 1.5rem) / 2);
    }

    .twister-before-after-card {
      padding: 0.75rem;
    }
  }
</style>

{%- liquid
  assign p = product
  assign variant = product.selected_or_first_available_variant
  assign imgs = product.images
  assign hero_image_url = 'https://m.media-amazon.com/images/I/61ZpwVMIMzL._AC_SX679_.jpg'
  assign hero_filter_id = 'twister-remove-white-bg-' | append: section.id
  assign before_after_images = 'https://cdn.shopify.com/s/files/1/0849/9606/3537/files/20260316-p3-4-pc.png||https://cdn.shopify.com/s/files/1/0849/9606/3537/files/20260316-p3-1-pc.png||https://cdn.shopify.com/s/files/1/0849/9606/3537/files/20260316-p3-2-pc.png||https://cdn.shopify.com/s/files/1/0849/9606/3537/files/20260316-p3-3-pc.png' | split: '||'
  assign compare_items = 'https://cdn.myshopage.com/af890d5a-9317-4602-a938-bf46d7e33f00/w400.jpg##Your home gym ends up cluttered with separate dumbbells and plates just to train your chest and arms.##Train your arms, chest, forearms and core with one compact tool instead of a pile of bulky gear.||https://cdn.myshopage.com/039bce89-25cb-4e30-5744-28d0686f2900/w400.jpg##Old spring-based twisters can snap back hard and give you almost no control.##The hydraulic resistance stays smooth and controlled, helping reduce harsh snap-back during every rep.||https://cdn.myshopage.com/2180b2a1-8bbf-4fae-e958-697de033d400/w400.jpg##It is easy to lose count of reps or wonder whether you are actually making progress.##The built-in LCD counter tracks each rep so you can focus on form and progression.||https://cdn.myshopage.com/083e8d3a-551e-4b51-d6fc-1b57ac4eaf00/w400.jpg##Most home equipment is either too easy or too intense, which slows down progress.##A quick turn of the knob lets you dial the resistance for beginners, daily training or tougher sets.' | split: '||'
-%}

