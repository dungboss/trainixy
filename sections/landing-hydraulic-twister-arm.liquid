{%- comment -%} Comparison table {%- endcomment -%}
<section class="bg-gradient-to-b from-black via-neutral-950 to-black text-white py-12 md:py-14">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center max-w-4xl mx-auto mb-8 md:mb-10">
      <p class="text-xs md:text-sm font-bold uppercase tracking-[0.2em] text-orange-500 mb-3">{{ comparison_table_label }}</p>
      <h2 class="text-2xl md:text-4xl font-black leading-tight mb-3">{{ comparison_table_heading }}</h2>
      {%- if comparison_table_subheading != blank -%}
        <p class="text-base md:text-lg text-gray-300 leading-relaxed">{{ comparison_table_subheading }}</p>
      {%- endif -%}
    </div>

    <div class="overflow-hidden md:overflow-x-auto">
      <div class="twister-table-wrap">
        <div class="twister-table-grid">
          <div class="twister-table-head-spacer">
            <h3 class="twister-table-feature-heading">{{ comparison_table_feature_heading }}</h3>
          </div>

          <div class="twister-table-head-cell twister-table-head-cell--primary">
            {%- if comparison_table_left_badge != blank -%}
              <span class="twister-table-pill">{{ comparison_table_left_badge }}</span>
            {%- endif -%}

            {%- if section.settings.comparison_table_left_image != blank -%}
              <img
                src="{{ section.settings.comparison_table_left_image | image_url: width: 320 }}"
                class="twister-table-product-image"
                alt="{{ comparison_table_left_title | escape }}"
                loading="lazy"
              >
            {%- elsif imgs[0] -%}
              <img
                src="{{ imgs[0] | image_url: width: 320 }}"
                class="twister-table-product-image"
                alt="{{ comparison_table_left_title | escape }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="twister-table-image-placeholder">Product</div>
            {%- endif -%}

            <h3 class="twister-table-column-title">{{ comparison_table_left_title }}</h3>
            {%- if comparison_table_left_subtitle != blank -%}
              <p class="twister-table-column-subtitle">{{ comparison_table_left_subtitle }}</p>
            {%- endif -%}
          </div>

          <div class="twister-table-head-cell twister-table-head-cell--secondary">
            {%- if comparison_table_right_badge != blank -%}
              <span class="twister-table-pill twister-table-pill--secondary">{{ comparison_table_right_badge }}</span>
            {%- endif -%}

            {%- if section.settings.comparison_table_right_image != blank -%}
              <img
                src="{{ section.settings.comparison_table_right_image | image_url: width: 320 }}"
                class="twister-table-product-image"
                alt="{{ comparison_table_right_title | escape }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="twister-table-image-placeholder">Alt</div>
            {%- endif -%}

            <h3 class="twister-table-column-title">{{ comparison_table_right_title }}</h3>
            {%- if comparison_table_right_subtitle != blank -%}
              <p class="twister-table-column-subtitle">{{ comparison_table_right_subtitle }}</p>
            {%- endif -%}
          </div>
        </div>

        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'comparison_row' -%}
              <div class="twister-table-row twister-table-grid" {{ block.shopify_attributes }}>
                <div class="twister-table-feature-cell">
                  <h3 class="twister-table-feature-title">{{ block.settings.title }}</h3>
                  {%- if block.settings.subtitle != blank -%}
                    <p class="twister-table-feature-subtitle">{{ block.settings.subtitle }}</p>
                  {%- endif -%}
                </div>

                <div class="twister-table-cell twister-table-cell--primary">
                  {%- case block.settings.left_status -%}
                    {%- when 'check' -%}
                      <span class="twister-table-status twister-table-status--check" aria-label="Included">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M6.5 12.5 10.2 16 17.5 8.5" stroke="currentColor" stroke-width="2.7" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                      </span>
                    {%- when 'cross' -%}
                      <span class="twister-table-status twister-table-status--cross" aria-label="Not included">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M8 8 16 16M16 8 8 16" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"></path>
                        </svg>
                      </span>
                    {%- else -%}
                      <span class="twister-table-status twister-table-status--dash" aria-hidden="true"></span>
                    {%- endcase -%}
                </div>

                <div class="twister-table-cell twister-table-cell--secondary">
                  {%- case block.settings.right_status -%}
                    {%- when 'check' -%}
                      <span class="twister-table-status twister-table-status--check" aria-label="Included">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M6.5 12.5 10.2 16 17.5 8.5" stroke="currentColor" stroke-width="2.7" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                      </span>
                    {%- when 'cross' -%}
                      <span class="twister-table-status twister-table-status--cross" aria-label="Not included">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M8 8 16 16M16 8 8 16" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"></path>
                        </svg>
                      </span>
                    {%- else -%}
                      <span class="twister-table-status twister-table-status--dash" aria-hidden="true"></span>
                    {%- endcase -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{%- comment -%} Before & After {%- endcomment -%}
<section class="bg-black text-white py-12 md:py-14">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center max-w-4xl mx-auto mb-6 md:mb-8">
      <p class="text-xs md:text-sm font-bold uppercase tracking-[0.24em] text-orange-500 mb-3">{{ before_after_label }}</p>
      <h2 class="text-xl md:text-3xl font-black leading-tight">{{ before_after_heading }}</h2>
    </div>

    <div
      class="twister-before-after-track gap-3 md:gap-6 overflow-x-auto snap-x snap-mandatory -mx-4 px-4 pb-2"
      data-before-after-track
      aria-label="Before and after gallery"
    >
      {%- for image in before_after_images -%}
        {%- if image != blank -%}
          <article class="twister-before-after-card snap-start" data-before-after-card>
            <div class="flex items-center gap-3 md:gap-5 mb-3 md:mb-4">
              <span class="text-zinc-200 text-lg md:text-2xl font-black leading-none">Before</span>
              <span class="h-px flex-1 bg-white/35"></span>
              <span class="text-orange-500 text-lg md:text-2xl font-black leading-none">After</span>
            </div>

            <img
              src="{{ image }}"
              class="twister-before-after-image"
              alt="Before and after result {{ forloop.index }}"
              loading="lazy"
              draggable="false"
            >
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%} Comparison {%- endcomment -%}
<section class="bg-white text-black py-12 md:py-14">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center max-w-4xl mx-auto mb-8 md:mb-10">
      <p class="text-xs md:text-sm font-bold uppercase tracking-[0.2em] text-orange-500 mb-3">{{ compare_label }}</p>
      <h2 class="text-2xl md:text-4xl font-black leading-tight mb-3">{{ compare_heading }}</h2>
      <p class="text-2xl md:text-3xl font-black text-amber-500 leading-tight">{{ compare_subheading }}</p>
    </div>

    <div class="twister-compare-track flex items-stretch md:grid md:grid-cols-2 xl:grid-cols-4 gap-4 md:gap-5 overflow-x-auto md:overflow-visible snap-x snap-mandatory md:snap-none -mx-4 px-4 md:mx-0 md:px-0 pb-2 md:pb-0">
      {%- for item in compare_items -%}
        {%- if item != blank -%}
          {%- assign compare_parts = item | split: '##' -%}
          <article class="twister-compare-card flex-none w-[280px] sm:w-[320px] md:w-auto md:min-w-0 snap-start">
            <div class="twister-compare-problem p-4 md:p-5 flex-1">
              <div class="twister-compare-title flex items-start gap-3 mb-4">
                <span class="w-8 h-8 rounded-full bg-red-500 text-white flex items-center justify-center flex-shrink-0">
                  <i data-lucide="alert-circle" class="w-4 h-4"></i>
                </span>
                <h3 class="text-lg md:text-xl font-black leading-snug">{{ compare_parts[1] }}</h3>
              </div>

              <img
                src="{{ compare_parts[0] }}"
                class="twister-compare-photo"
                alt="{{ compare_parts[1] | escape }}"
                loading="lazy"
              >
            </div>

            <div class="twister-compare-solution p-4 md:p-5">
              <div class="flex items-start gap-3">
                <span class="w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center flex-shrink-0">
                  <i data-lucide="check" class="w-4 h-4"></i>
                </span>
                <div class="twister-compare-solution-copy">
                  <p class="text-lg md:text-xl font-black leading-none mb-2">Our Solution:</p>
                  <p class="text-base md:text-lg leading-relaxed font-medium">{{ compare_parts[2] }}</p>
                </div>
              </div>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%} Guarantee banner {%- endcomment -%}
<div class="bg-gradient-to-r from-orange-600 to-red-700 py-6 text-center">
  <h3 class="text-2xl font-bold text-white uppercase flex justify-center items-center gap-2">
    <i data-lucide="shield-check" class="w-8 h-8"></i> {{ guarantee_text }}
  </h3>
</div>

{%- comment -%} Buy section {%- endcomment -%}
<section id="buy-section" class="bg-white text-black py-16">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="flex flex-col md:flex-row gap-12">

      {%- comment -%} Gallery {%- endcomment -%}
      <div class="w-full md:w-1/2">
        <div class="border border-gray-200 rounded-2xl overflow-hidden mb-4 relative p-4 bg-gray-50">
          {%- if variant.compare_at_price > variant.price -%}
            {%- assign discount_pct = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price -%}
            <div class="absolute top-4 left-4 bg-orange-600 text-white text-xs font-bold px-3 py-1 rounded-full z-10">-{{ discount_pct }}%</div>
          {%- endif -%}
          {%- if imgs[0] -%}
            <img id="main-product-img" src="{{ imgs[0] | image_url: width: 600 }}" class="w-full object-contain h-[400px]" alt="{{ p.title }}">
          {%- else -%}
            <img id="main-product-img" src="https://placehold.co/600x600/f9fafb/374151?text=[Product+Image]" class="w-full object-contain h-[400px]" alt="{{ p.title }}">
          {%- endif -%}
        </div>
        <div class="flex gap-4 overflow-x-auto pb-2">
          {%- for img in imgs limit: 5 -%}
            <img
              src="{{ img | image_url: width: 100 }}"
              class="w-20 h-20 border-2 rounded-lg cursor-pointer flex-shrink-0 hover:border-orange-500 transition {% if forloop.first %}border-orange-500{% else %}border-gray-200{% endif %}"
              alt="Image {{ forloop.index }}"
              onclick="document.getElementById('main-product-img').src='{{ img | image_url: width: 600 }}'; document.querySelectorAll('.thumb-list img').forEach(t=>t.classList.replace('border-orange-500','border-gray-200')); this.classList.replace('border-gray-200','border-orange-500')"
            >
          {%- else -%}
            {%- for i in (1..4) -%}
              <img src="https://placehold.co/100x100/f9fafb/374151?text=[{{ i }}]" class="w-20 h-20 border-2 rounded-lg cursor-pointer {% if forloop.first %}border-orange-500{% else %}border-gray-200{% endif %}" alt="Image {{ i }}">
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Product info {%- endcomment -%}
      <div class="w-full md:w-1/2 flex flex-col justify-center">
        <div class="flex items-center gap-2 mb-2">
          <div class="flex text-yellow-400">
            {%- for i in (1..5) -%}<i data-lucide="star" class="w-4 h-4 fill-current"></i>{%- endfor -%}
          </div>
          <span class="text-sm text-gray-500">({{ p.metafields.reviews.rating_count | default: '856' }} reviews)</span>
          {%- if variant.available -%}
            <span class="text-sm text-green-600 font-medium ml-2 flex items-center">
              <i data-lucide="check-circle-2" class="w-4 h-4 mr-1"></i> In Stock
            </span>
          {%- else -%}
            <span class="text-sm text-red-500 font-medium ml-2">Out of Stock</span>
          {%- endif -%}
        </div>

        <h2 class="text-3xl font-bold mb-4">{{ p.title }}</h2>

        <div class="flex items-baseline gap-4 mb-6">
          <span class="text-4xl font-black text-orange-600">{{ variant.price | money }}</span>
          {%- if variant.compare_at_price > variant.price -%}
            <span class="text-xl text-gray-400 line-through">{{ variant.compare_at_price | money }}</span>
          {%- endif -%}
        </div>

        <div class="bg-orange-50 border border-orange-100 rounded-lg p-4 mb-6">
          <p class="text-sm text-orange-800 font-medium">🔥 12 people are viewing this product right now.</p>
        </div>

        {%- if p.variants.size > 1 -%}
          <div class="mb-6">
            <p class="font-semibold mb-2">Variant:</p>
            <select id="variant-select" class="border border-gray-300 rounded-lg px-4 py-2 text-base w-full focus:outline-none focus:border-orange-500">
              {%- for v in p.variants -%}
                <option value="{{ v.id }}" {% unless v.available %}disabled{% endunless %}>
                  {{ v.title }} — {{ v.price | money }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}

        <div class="mb-6">
          <p class="font-semibold mb-2">Quantity:</p>
          <div class="flex items-center border border-gray-300 rounded-lg w-32">
            <button onclick="updateQty(-1)" class="px-3 py-2 text-gray-600 hover:bg-gray-100"><i data-lucide="minus" class="w-4 h-4"></i></button>
            <input type="text" id="quantity-input" value="1" readonly class="w-full text-center font-semibold text-lg outline-none bg-transparent">
            <button onclick="updateQty(1)" class="px-3 py-2 text-gray-600 hover:bg-gray-100"><i data-lucide="plus" class="w-4 h-4"></i></button>
          </div>
        </div>

        <div class="flex flex-col gap-3 mb-8">
          <button
            id="add-to-cart-btn"
            onclick="handleAddToCart(false)"
            data-variant-id="{{ variant.id }}"
            class="w-full bg-white border-2 border-orange-600 text-orange-600 font-bold py-4 rounded-xl text-lg hover:bg-orange-50 transition disabled:opacity-50"
          >
            ADD TO CART
          </button>
          <button
            id="buy-now-btn"
            onclick="handleAddToCart(true)"
            data-variant-id="{{ variant.id }}"
            class="w-full bg-orange-600 text-white font-bold py-4 rounded-xl text-lg hover:bg-orange-700 transition shadow-lg flex justify-center items-center gap-2 disabled:opacity-50"
          >
            BUY NOW <i data-lucide="chevron-right" class="w-5 h-5"></i>
          </button>
        </div>

      </div>
    </div>
  </div>
</section>

{%- comment -%} FAQ {%- endcomment -%}
<section class="py-16 bg-neutral-950">
  <div class="container mx-auto px-4 max-w-3xl">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold uppercase mb-4">Frequently Asked Questions</h2>
      <div class="w-24 h-1 bg-orange-500 mx-auto"></div>
    </div>
    <div class="space-y-4">
      <details class="bg-neutral-900 border border-neutral-800 rounded-xl group open:border-orange-500 transition">
        <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold list-none">
          <span>Is it safe for beginners?</span>
          <i data-lucide="chevron-down" class="w-5 h-5 text-orange-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4"></i>
        </summary>
        <p class="px-6 pb-5 text-gray-400 text-sm leading-relaxed">Absolutely. The lowest setting (22 lbs) is perfect for warmups or those just starting out.</p>
      </details>
      <details class="bg-neutral-900 border border-neutral-800 rounded-xl group open:border-orange-500 transition">
        <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold list-none">
          <span>How do I adjust the resistance?</span>
          <i data-lucide="chevron-down" class="w-5 h-5 text-orange-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4"></i>
        </summary>
        <p class="px-6 pb-5 text-gray-400 text-sm leading-relaxed">It's simple! Just turn the central knob. Turn right to increase resistance and left to decrease it.</p>
      </details>
      <details class="bg-neutral-900 border border-neutral-800 rounded-xl group open:border-orange-500 transition">
        <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold list-none">
          <span>Will the hydraulic oil leak?</span>
          <i data-lucide="chevron-down" class="w-5 h-5 text-orange-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4"></i>
        </summary>
        <p class="px-6 pb-5 text-gray-400 text-sm leading-relaxed">Our cylinder is double-sealed and made of aviation-grade components to prevent any leaking.</p>
      </details>
      <details class="bg-neutral-900 border border-neutral-800 rounded-xl group open:border-orange-500 transition">
